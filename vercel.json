{
  "version": 2,
  "routes": [
    { "src": "/api/genera-scheda", "dest": "/api/genera-scheda.js" },
    { "src": "/api/schede", "dest": "/api/schede.js" },
    { "src": "/api/scheda", "dest": "/api/scheda.js" },
    { "src": "/schede.html", "dest": "/public/schede.html" },
    { "src": "/scheda.html", "dest": "/public/scheda.html" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
